---
import TopNav from "../../components/TopNav.astro";
import type { Card } from "../../types/card";
import rawData from "../../data/cards.json";
import DataCard from "../../components/DataCard.astro";
import "../../styles/global.css";

const cards = (rawData.cards as Card[]).sort((a, b) =>
  a.name.localeCompare(b.name)
);

const seriesGroups = Array.from(new Set(cards.map(c => c.series))).map(series => ({
  series,
  cards: cards.filter(c => c.series === series)
}));

const timelineCards = [...rawData.cards].sort((a, b) =>
  new Date(a.acquired).getTime() - new Date(b.acquired).getTime()
);
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Decks</title>
  </head>
  <body>
    <TopNav />
    <main>
      <h1>Cards</h1>

<!-- Brand Filter -->
<label for="brand-filter">Filter by Brand:</label>
<select id="brand-filter">
  <option value="all">All</option>
  {Array.from(new Set(cards.map(card => card.brand))).map(brand => (
    <option value={brand}>{brand}</option>
  ))}
</select>

<!-- Sort -->
<label for="sort-select">Sort by:</label>
<select id="sort-select">
  <option value="alpha">Alphabetical</option>
  <option value="newest">Newest</option>
  <option value="oldest">Oldest</option>
</select>

<!-- Search -->
<input id="search-input" type="text" placeholder="Search by name..." />

<!-- Card count -->
<p id="card-count" class="card-count"></p>

<!-- Card view grouped by series -->
<div id="series-container">
  {seriesGroups.map(group => (
    <div class="series-group" data-series={group.series}>
      <h3 class="series-title">{group.series}</h3>
      <section class="card-grid">
        {group.cards.map((card) => (
          <DataCard card={card} />
        ))}
      </section>
    </div>
  ))}
</div>

<!-- Modal -->
<div id="card-modal" class="modal hidden">
  <div class="modal-content">
    <button id="close-modal" class="modal-close" aria-label="Close">×</button>
    <img id="modal-image" src="" alt="" style="width: 100%; border-radius: 4px; margin-bottom: 1rem;" />
    <h2 id="modal-title"></h2>
    <ul id="modal-details"></ul>
  </div>
</div>

<!-- Timeline -->
<h2>Collection Timeline</h2>
<div class="timeline-controls">
  <button id="zoom-in">+</button>
  <button id="zoom-out">−</button>
  <span id="zoom-label" class="zoom-label"></span>
</div>
<div class="timeline-wrapper">
  <div class="timeline-scroll" id="timeline-scroll">
    <div class="timeline-track" id="timeline-track">
      <div class="timeline-line"></div>
    </div>
  </div>
</div>

    </main>
  </body>

<script>
  const modalRaw = document.getElementById("card-modal") as HTMLDivElement | null;
  const modalContentRaw = modalRaw?.querySelector(".modal-content") as HTMLDivElement | null;
  const titleElRaw = document.getElementById("modal-title") as HTMLHeadingElement | null;
  const detailsElRaw = document.getElementById("modal-details") as HTMLUListElement | null;
  const closeBtnRaw = document.getElementById("close-modal") as HTMLButtonElement | null;

  if (!modalRaw || !modalContentRaw || !titleElRaw || !detailsElRaw || !closeBtnRaw) {
    throw new Error("Modal elements missing from DOM");
  }

  const modal = modalRaw;
  const modalContent = modalContentRaw;
  const titleEl = titleElRaw;
  const detailsEl = detailsElRaw;
  const closeBtn = closeBtnRaw;

  function closeModal() {
    modal.classList.add("hidden");
  }

  function openModal(card: CardData, imageUrl: string) {
    titleEl.textContent = card.name;
    const imgEl = document.getElementById("modal-image") as HTMLImageElement;
    if (imgEl) {
      imgEl.src = imageUrl;
      imgEl.alt = card.name;
    }
    detailsEl.innerHTML = `
      <li><strong>Brand:</strong> ${card.brand}</li>
      <li><strong>Series:</strong> ${card.series}</li>
      <li><strong>Acquired:</strong> ${card.acquired}</li>
    `;
    modal.classList.remove("hidden");
  }

  function attachCardListeners() {
    document
      .querySelectorAll<HTMLButtonElement>(".data-card")
      .forEach((cardEl) => {
        cardEl.addEventListener("click", () => {
          const raw = cardEl.dataset.card;
          if (!raw) return;
          let card: CardData;
          try {
            card = JSON.parse(raw);
          } catch {
            return;
          }
          const imageUrl = cardEl.dataset.image || '';
          openModal(card, imageUrl);
        });
      });
  }

  attachCardListeners();

  closeBtn.addEventListener("click", closeModal);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) {
      closeModal();
    }
  });

  modal.addEventListener("click", (e) => {
    if (!modalContent.contains(e.target as Node)) {
      closeModal();
    }
  });

  type CardData = {
    name: string;
    brand: string;
    series: string;
    acquired: string;
  };
</script>

<script>
  const filterSelect = document.getElementById("brand-filter") as HTMLSelectElement;
  const sortSelect = document.getElementById("sort-select") as HTMLSelectElement;
  const searchInput = document.getElementById("search-input") as HTMLInputElement;
  const seriesContainer = document.getElementById("series-container") as HTMLElement;
  const cardCountEl = document.getElementById("card-count") as HTMLParagraphElement;

  const allCards = Array.from(document.querySelectorAll<HTMLButtonElement>(".data-card")).map(el => ({
    el,
    data: JSON.parse(el.dataset.card || '{}'),
    image: el.dataset.image || '',
    brand: el.dataset.brand || '',
    series: (JSON.parse(el.dataset.card || '{}')).series as string
  }));

  function applyFilters() {
    const brand = filterSelect.value;
    const sort = sortSelect.value;
    const search = searchInput.value.toLowerCase();

    let filtered = allCards.filter(card => {
      const matchesBrand = brand === "all" || card.brand === brand;
      const matchesSearch = card.data.name.toLowerCase().includes(search);
      return matchesBrand && matchesSearch;
    });

    filtered.sort((a, b) => {
      if (sort === "alpha") return a.data.name.localeCompare(b.data.name);
      if (sort === "newest") return new Date(b.data.acquired).getTime() - new Date(a.data.acquired).getTime();
      if (sort === "oldest") return new Date(a.data.acquired).getTime() - new Date(b.data.acquired).getTime();
      return 0;
    });

    cardCountEl.textContent = `${filtered.length} deck${filtered.length !== 1 ? 's' : ''}`;

    const grouped = new Map<string, typeof filtered>();
    filtered.forEach(card => {
      if (!grouped.has(card.series)) grouped.set(card.series, []);
      grouped.get(card.series)!.push(card);
    });

    seriesContainer.innerHTML = '';
    grouped.forEach((groupCards, series) => {
      const groupDiv = document.createElement('div');
      groupDiv.className = 'series-group';
      groupDiv.dataset.series = series;

      const title = document.createElement('h3');
      title.className = 'series-title';
      title.textContent = series;
      groupDiv.appendChild(title);

      const grid = document.createElement('section');
      grid.className = 'card-grid';
      groupCards.forEach(card => grid.appendChild(card.el));
      groupDiv.appendChild(grid);

      seriesContainer.appendChild(groupDiv);
    });

    (window as any).attachCardListeners?.();
  }

  (window as any).attachCardListeners = () => {
    document.querySelectorAll<HTMLButtonElement>(".data-card").forEach((cardEl) => {
      cardEl.addEventListener("click", () => {
        const raw = cardEl.dataset.card;
        if (!raw) return;
        const card = JSON.parse(raw);
        const imageUrl = cardEl.dataset.image || '';
        const modal = document.getElementById("card-modal");
        const titleEl = document.getElementById("modal-title");
        const detailsEl = document.getElementById("modal-details");
        const imgEl = document.getElementById("modal-image") as HTMLImageElement;
        if (!modal || !titleEl || !detailsEl) return;
        if (titleEl) titleEl.textContent = card.name;
        if (imgEl) { imgEl.src = imageUrl; imgEl.alt = card.name; }
        if (detailsEl) detailsEl.innerHTML = `
          <li><strong>Brand:</strong> ${card.brand}</li>
          <li><strong>Series:</strong> ${card.series}</li>
          <li><strong>Acquired:</strong> ${card.acquired}</li>
        `;
        modal.classList.remove("hidden");
      });
    });
  };

  filterSelect.addEventListener("change", applyFilters);
  sortSelect.addEventListener("change", applyFilters);
  searchInput.addEventListener("input", applyFilters);

  applyFilters();
</script>

<script>
  const timelineData = [
    {name:"Classic Blue", acquired:"2022-01-01"},
    {name:"Marquis", acquired:"2022-05-08"},
    {name:"Fyrebird", acquired:"2022-09-02"},
    {name:"Spellbound", acquired:"2022-12-28"},
    {name:"Cypher", acquired:"2023-04-24"},
    {name:"Dragon Gold", acquired:"2023-08-19"},
    {name:"Dragon Silver", acquired:"2023-12-14"},
    {name:"Dragon Red", acquired:"2024-04-09"},
    {name:"NOC Orange", acquired:"2024-08-04"},
    {name:"Mastermind", acquired:"2024-11-29"},
    {name:"M&M Brown", acquired:"2025-03-26"},
    {name:"M&M Yellow", acquired:"2025-07-21"},
    {name:"M&M White", acquired:"2025-11-15"},
    {name:"Stitch", acquired:"2026-03-12"},
    {name:"Bees Red", acquired:"2026-07-03"}
  ];

  const track = document.getElementById("timeline-track") as HTMLElement;
  const zoomInBtn = document.getElementById("zoom-in") as HTMLButtonElement;
  const zoomOutBtn = document.getElementById("zoom-out") as HTMLButtonElement;
  const zoomLabel = document.getElementById("zoom-label") as HTMLSpanElement;

  const MS_PER_DAY = 1000 * 60 * 60 * 24;
  const ZOOM_LEVELS = [180, 365, 730, 1460];
  let zoomIndex = 1;

  const dates = timelineData.map(c => new Date(c.acquired).getTime());
  const minDate = Math.min(...dates);
  const maxDate = Math.max(...dates);

  function renderTimeline() {
    const daysVisible = ZOOM_LEVELS[zoomIndex];
    const pxPerDay = track.parentElement!.clientWidth / daysVisible;
    const totalDays = (maxDate - minDate) / MS_PER_DAY;
    const trackWidth = Math.max(totalDays * pxPerDay, track.parentElement!.clientWidth);

    zoomLabel.textContent = `${daysVisible} days visible`;

    track.style.width = trackWidth + 'px';
    track.innerHTML = '<div class="timeline-line"></div>';

    timelineData.forEach((card, i) => {
      const cardDate = new Date(card.acquired).getTime();
      const dayOffset = (cardDate - minDate) / MS_PER_DAY;
      const x = dayOffset * pxPerDay;
      const above = i % 2 === 0;

      const point = document.createElement('div');
      point.className = 'timeline-point';
      point.style.left = x + 'px';

      const dot = document.createElement('div');
      dot.className = 'timeline-dot';

      const label = document.createElement('div');
      label.className = `timeline-label ${above ? 'above' : 'below'}`;
      label.innerHTML = `<span class="timeline-name">${card.name}</span><span class="timeline-date">${card.acquired}</span>`;

      point.appendChild(dot);
      point.appendChild(label);
      track.appendChild(point);
    });

    addYearMarkers(minDate, maxDate, pxPerDay);
  }

  function addYearMarkers(min: number, max: number, pxPerDay: number) {
    const startYear = new Date(min).getFullYear();
    const endYear = new Date(max).getFullYear();
    for (let y = startYear; y <= endYear; y++) {
      const yearMs = new Date(`${y}-01-01`).getTime();
      if (yearMs < min) continue;
      const dayOffset = (yearMs - min) / MS_PER_DAY;
      const x = dayOffset * pxPerDay;
      const marker = document.createElement('div');
      marker.className = 'timeline-year';
      marker.style.left = x + 'px';
      marker.textContent = String(y);
      track.appendChild(marker);
    }
  }

  zoomInBtn.addEventListener("click", () => {
    if (zoomIndex > 0) { zoomIndex--; renderTimeline(); }
  });

  zoomOutBtn.addEventListener("click", () => {
    if (zoomIndex < ZOOM_LEVELS.length - 1) { zoomIndex++; renderTimeline(); }
  });

  renderTimeline();
</script>

</html>