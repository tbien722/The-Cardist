---
import fs from "fs";
import path from "path";

const hobbiesDir = path.resolve("src/pages/hobbies");

const hobbies = fs.existsSync(hobbiesDir)
  ? fs.readdirSync(hobbiesDir).filter((name) =>
      fs.statSync(path.join(hobbiesDir, name)).isDirectory()
    )
  : [];
---

<nav>
  <ul>
    <li class="home-link"><a href="/">Home</a></li>
    {hobbies.map((hobby) => (
      <li>
        <a href={`/hobbies/${hobby}/`}>
        {hobby.charAt(0).toUpperCase() + hobby.slice(1)}</a>
      </li>
    ))}
  </ul>
</nav>