---
import type { Card } from "../types/card";

type Props = {
  card: Card;
};

const { card } = Astro.props as Props;
const base = import.meta.env.BASE_URL;

const deckImages: Record<string, string> = {
  bicycleblue:      `${base}cards/bicycle-front-blueclassic.jpg`,
  blueriderback:    `${base}cards/bicycle-front-blueriderback.jpg`,
  aviatorblue:      `${base}cards/aviator-front-blue.jpg`,
  aviatorred:       `${base}cards/aviator-front-red.jpg`,
  beeRed:           `${base}cards/bee-front-beered.jpg`,
  marquis:          `${base}cards/bicycle-front-marquis.jpg`,
  fyrebird:         `${base}cards/bicycle-front-fyrebird.jpg`,
  spellbound:       `${base}cards/bicycle-front-spell.jpg`,
  cypher:           `${base}cards/bicycle-front-cypher.jpg`,
  muralis:          `${base}cards/bicycle-front-muralis.jpg`,
  stargazer:        `${base}cards/bicycle-front-stargazer.jpg`,
  seaking:          `${base}cards/bicycle-front-sea-king.jpg`,
  waves:            `${base}cards/front-waves.jpg`,
  gDragon:          `${base}cards/bicycle-front-gdragon.jpg`,
  sDragon:          `${base}cards/bicycle-front-sdragon.jpg`,
  rDragon:          `${base}cards/bicycle-front-rdragon.jpg`,
  acdc:             `${base}cards/bicycle-front-acdc.jpg`,
  gunsnroses:       `${base}cards/bicycle-front-gunsnroses.jpg`,
  stitch:           `${base}cards/bicycle-front-stitch.jpg`,
  batman:           `${base}cards/theory11-front-batman.jpg`,
  dune:             `${base}cards/theory11-front-dune.jpg`,
  gameshubblue:     `${base}cards/gameshub-front-blue.jpg`,
  gameshubcats:     `${base}cards/gameshub-front-cats.jpg`,
  gameshubred:      `${base}cards/gameshub-front-red.jpg`,
  artisan:          `${base}cards/theory11-front-artisan.jpg`,
  beowulf:          `${base}cards/kings-wild-front-beowulf.jpg`,
  banksy:           `${base}cards/misc-front-banksy.jpg`,
  dbrand:           `${base}cards/misc-front-dbrand.jpg`,
  nocOrange:        `${base}cards/noc-front-nocorange.jpg`,
  elf:              `${base}cards/misc-front-elf.jpg`,
  guinness:         `${base}cards/misc-front-guinness.jpg`,
  mastermind:       `${base}cards/keymaster-front-mastermind.jpg`,
  anthropology:     `${base}cards/stockholm17-front-anthropology.jpg`,
  orchid:           `${base}cards/tallyho-front-orchid.jpg`,
  miscgoodsyellow:  `${base}cards/miscgoods-front-yellow.jpg`,
  mmBrown:          `${base}cards/mm-front-mmbrown.png`,
  mmYellow:         `${base}cards/mm-front-mmyellow.png`,
  mmWhite:          `${base}cards/mm-front-mmwhite.png`,
};

const backgroundUrl = deckImages[card.deckType || ''] || `${base}cards/drake-card.jpg`;
---

<button
  class="data-card"
  style={`background: url('${backgroundUrl}') no-repeat center center; background-size: cover; border-radius: 4px;`}
  data-card={JSON.stringify(card)}
  data-brand={card.brand}
  data-image={backgroundUrl}
  aria-label={`View details for ${card.name}`}
>
  {card.limited && (
    <span class="limited-badge">Limited</span>
  )}
</button>